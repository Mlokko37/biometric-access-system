# Database Configuration (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=biometric_access_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Application Configuration
APP_SECRET_KEY=your-secret-key-here-change-in-production
APP_DEBUG=False
APP_PORT=5000

# Biometric System Configuration
FINGERPRINT_THRESHOLD=60
FACIAL_THRESHOLD=0.6
MAX_LOGIN_ATTEMPTS=3
SESSION_TIMEOUT=30  # minutes

# Hardware Configuration
FINGERPRINT_SENSOR_PORT=/dev/ttyUSB0  # Linux/Mac
# FINGERPRINT_SENSOR_PORT=COM3        # Windows
CAMERA_INDEX=0

# Security
ENCRYPTION_KEY=your-encryption-key-here
LOG_LEVEL=INFO

# Paths
TEMPLATE_STORAGE_PATH=./data/sample_templates/
LOG_STORAGE_PATH=./data/logs/
BACKUP_PATH=./data/backups/