# Supabase Database Configuration - USING TRANSACTION POOLER (IPv4 Compatible)
SUPABASE_DB_HOST=aes-1-eu-central-1.pooler.supabase.com
SUPABASE_DB_PORT=6543
SUPABASE_DB_USER=postgres.gqlupibjdy@thnkhwkr1
SUPABASE_DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD_HERE
SUPABASE_DB_NAME=postgres

# Alternative: Use connection string (URL encoded - @ symbol becomes %40)
# Note: The @ in the username needs to be URL encoded as %40
SUPABASE_DATABASE_URL=postgresql://postgres.gqlupibjdy%40thnkhwkr1:%24Collotynho254@aes-1-eu-central-1.pooler.supabase.com:6543/postgres

# Application Configuration
APP_SECRET_KEY=YOUR_APP_SECRET_KEY_HERE
APP_DEBUG=True
APP_PORT=5000

# Biometric System Configuration
FINGERPRINT_THRESHOLD=60
FACIAL_THRESHOLD=0.6
MAX_LOGIN_ATTEMPTS=3
SESSION_TIMEOUT=30

# Hardware Configuration
FINGERPRINT_SENSOR_PORT=COM3
FINGERPRINT_SCANNER_ID=scanner_1
ACCESS_CONTROLLER_PORT=COM4
CAMERA_INDEX=0
CAMERA_ID=camera_1

# Manufacturer-specific devices
ZKTECO_IP=192.168.1.201
ZKTECO_PORT=4370
HIKVISION_IP=192.168.1.100
HIKVISION_PORT=80
HIKVISION_USERNAME=admin
HIKVISION_PASSWORD=YOUR_HIKVISION_PASSWORD_HERE
SUPREMA_IP=192.168.1.200
SUPREMA_PORT=443
SUPREMA_USERNAME=admin
SUPREMA_PASSWORD=YOUR_SUPREMA_PASSWORD_HERE

# Disable simulation modes for REAL HARDWARE
ENROLLMENT_SIMULATION=false
HARDWARE_SIMULATION=false

# Security
ENCRYPTION_KEY=YOUR_ENCRYPTION_KEY_HERE
LOG_LEVEL=INFO

# Paths
TEMPLATE_STORAGE_PATH=./data/sample_templates/
LOG_STORAGE_PATH=./data/logs/
BACKUP_PATH=./data/backups/
FIREBASE_ADMIN_KEY=YOUR_FIREBASE_ADMIN_KEY_HERE